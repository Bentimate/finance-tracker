<!--
  AndroidManifest.xml — additions for Phase 4
  ─────────────────────────────────────────────
  Add the two blocks below inside your existing <application> tag.

  1. WidgetEntryActivity  — the transparent RN activity launched by the widget.
  2. FinanceWidget        — the AppWidgetProvider receiver.

  Replace "com.financetracker" with your actual applicationId if it differs.
-->

<!-- ① Widget entry activity (transparent, dialog-style) -->
<activity
    android:name=".WidgetEntryActivity"
    android:theme="@style/Theme.AppCompat.Dialog"
    android:exported="false"
    android:windowSoftInputMode="adjustResize" />

<!-- ② Widget receiver -->
<receiver
    android:name=".FinanceWidget"
    android:exported="true">
    <intent-filter>
        <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
    </intent-filter>
    <meta-data
        android:name="android.appwidget.provider"
        android:resource="@xml/widget_info" />
</receiver>
