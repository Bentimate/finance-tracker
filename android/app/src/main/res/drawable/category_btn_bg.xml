<?xml version="1.0" encoding="utf-8"?>
<!--
  Dropdown-trigger button background.
  Matches the input field style so the two fields feel like a cohesive form.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed state — slightly darker fill -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#f3f4f6" />
            <stroke
                android:width="1.5dp"
                android:color="#6366f1" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#f9fafb" />
            <stroke
                android:width="1.5dp"
                android:color="#e5e7eb" />
            <corners android:radius="8dp" />
        </shape>
    </item>

</selector>
