<?xml version="1.0" encoding="utf-8"?>
<!--
  Layout for WidgetEntryActivity.
  Rendered inside Theme.AppCompat.Light.Dialog so Android automatically
  frames this as a floating dialog — no explicit dialog chrome needed here.

  Design matches the app aesthetic:
    · White surface, #f9fafb background for input fields
    · #6366f1 indigo accent for the save button
    · #111827 primary text, #6b7280 secondary
    · 12dp corner radius on inputs/buttons
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/white">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add A Transaction"
        android:textColor="#111827"
        android:textSize="17sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <!-- Amount field -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AMOUNT"
        android:textColor="#9ca3af"
        android:textSize="10sp"
        android:letterSpacing="0.08"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/input_background"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="S$"
            android:textColor="#6b7280"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginEnd="4dp" />

        <EditText
            android:id="@+id/amount_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="none"
            android:hint="0.00"
            android:textColorHint="#9ca3af"
            android:textColor="#111827"
            android:textSize="17sp"
            android:textStyle="bold"
            android:background="@null"
            android:importantForAutofill="no"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:cursorVisible="false"
            android:longClickable="false"
            android:textIsSelectable="false" />

    </LinearLayout>

    <!-- Amount error -->
    <TextView
        android:id="@+id/amount_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#ef4444"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"
        android:visibility="gone" />

    <!-- Custom amount keypad -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <Button
                android:id="@+id/key_1"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="1"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#111827"
                android:background="@drawable/input_background" />

            <Space
                android:layout_width="6dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/key_2"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="2"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#111827"
                android:background="@drawable/input_background" />

            <Space
                android:layout_width="6dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/key_3"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="3"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#111827"
                android:background="@drawable/input_background" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <Button
                android:id="@+id/key_4"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="4"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#111827"
                android:background="@drawable/input_background" />

            <Space
                android:layout_width="6dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/key_5"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="5"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#111827"
                android:background="@drawable/input_background" />

            <Space
                android:layout_width="6dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/key_6"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="6"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#111827"
                android:background="@drawable/input_background" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <Button
                android:id="@+id/key_7"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="7"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#111827"
                android:background="@drawable/input_background" />

            <Space
                android:layout_width="6dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/key_8"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="8"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#111827"
                android:background="@drawable/input_background" />

            <Space
                android:layout_width="6dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/key_9"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="9"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#111827"
                android:background="@drawable/input_background" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/key_sign"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="+/-"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#111827"
                android:background="@drawable/input_background" />

            <Space
                android:layout_width="6dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/key_0"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="0"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#111827"
                android:background="@drawable/input_background" />

            <Space
                android:layout_width="6dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/key_decimal"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="."
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#111827"
                android:background="@drawable/input_background" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <Button
                android:id="@+id/key_clear"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:text="AC"
                android:textAllCaps="false"
                android:textColor="#111827"
                android:background="@drawable/input_background" />

            <Space
                android:layout_width="6dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/key_backspace"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:text="&#x232b;"
                android:textAllCaps="false"
                android:textColor="#111827"
                android:background="@drawable/input_background" />
        </LinearLayout>
    </LinearLayout>

    <!-- Category field -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CATEGORY"
        android:textColor="#9ca3af"
        android:textSize="10sp"
        android:letterSpacing="0.08"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp" />

    <Button
        android:id="@+id/category_btn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Select a category"
        android:textColor="#6b7280"
        android:textSize="14sp"
        android:gravity="start|center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:background="@drawable/category_btn_bg"
        android:layout_marginBottom="4dp"
        style="?attr/borderlessButtonStyle" />

    <!-- Category error -->
    <TextView
        android:id="@+id/category_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#ef4444"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"
        android:visibility="gone" />

    <!-- Save button -->
    <Button
        android:id="@+id/save_btn"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Save"
        android:textColor="#ffffff"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/dialog_button_bg"
        android:layout_marginTop="14dp"
        style="?attr/borderlessButtonStyle" />

</LinearLayout>
